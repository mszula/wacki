# All built binaries (engine, debug build, tools, test runner) and
# their debug-info bundles land under /dist/. The whole directory
# is excluded from git so the source tree never carries build
# artefacts. The bare /wacki and /wacki-debug names are kept as a
# safety net for stray builds left over from before the dist/
# migration.
/dist/
/wacki
/wacki-debug

# Generated by tools/embed-pe-data from data/WACKI.EXE; the engine
# binary links it in to satisfy PeLoaderRead. Recreated on demand;
# never committed.
src/embedded_wacki_pe.c

*.dSYM/
*.o
*.a

# Runtime saves + per-user display prefs
Wacki.sav
wacki.cfg

# Logs / diagnostics
*.log

# Game assets (symlinked, not committed)
/data
/data/

# Debug screenshots / dumps
*.bmp
# Whitelist the window-icon BMP — it's the actual source asset for
# src/embedded_icon.c, not a debug dump.
!assets/icons/wacki-window.bmp

# Reverse-engineering analysis notes (kept locally, not pushed)
ANALYSIS.md
ANALYSIS/

# Hugo landing-site build output and caches (website/ is the Hugo project;
# only the source — content/, layouts/, static/, hugo.toml — is committed).
/website/public/
/website/resources/
/website/.hugo_build.lock

# Editor / OS / tool metadata
.DS_Store
.idea/
.vscode/
.claude/
*.swp
