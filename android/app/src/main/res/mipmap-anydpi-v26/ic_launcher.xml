<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon (API 26+). Full-bleed cover art as the background so the icon
     fills the launcher's masked shape edge-to-edge like other apps; without
     this, launchers wrap the legacy bitmap in a frame and shrink it. The art is
     opaque and square, so the transparent foreground just lets it show through. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@mipmap/ic_launcher_art" />
    <foreground android:drawable="@android:color/transparent" />
</adaptive-icon>
